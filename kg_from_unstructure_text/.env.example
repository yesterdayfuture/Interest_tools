# 应用配置
DEBUG=true

# SQLite配置
SQLITE_DB_PATH=./data/ontology.db

# Nebula Graph配置
NEBULA_HOST=127.0.0.1
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=xxx
NEBULA_SPACE=xxx

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-ada-002

# 嵌入模型独立配置（可选）
# 如果不设置，将使用上面的OpenAI配置
EMBEDDING_API_KEY=          # 嵌入模型API Key，为空则使用OPENAI_API_KEY
EMBEDDING_BASE_URL=         # 嵌入模型Base URL，为空则使用OPENAI_BASE_URL
EMBEDDING_MODEL_NAME=text-embedding-ada-002  # 嵌入模型名称

# ChromaDB配置
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=customer_service_docs

# RAG配置
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800