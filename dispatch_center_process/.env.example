# 应用配置
APP_NAME=Task Scheduler Center
APP_VERSION=1.0.0
APP_DESCRIPTION=高性能任务调度系统

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./task_scheduler.db
DATABASE_ECHO=false

# 任务调度配置
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_SECONDS=300

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# CORS 配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
